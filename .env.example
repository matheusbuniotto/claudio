GROQ_API_KEY=your_groq_api_key_here

# Optional overrides
CLAUDIO_TTS_ENABLED=1        # set to 0 to disable TTS entirely
CLAUDIO_TTS_VOICE=Aaliyah-PlayAI
CLAUDIO_TTS_SPEED=1.0

# If GROQ_API_KEY is unset or Groq fails, the hook falls back to the system
# `say` command (macOS) or `espeak` (Linux) — no extra config required.
